{
  "name": "knip-gui",
  "version": "0.3.0",
  "description": "Web GUI for knip — browse, fix, and commit unused-code cleanups",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arilas/knip-gui.git"
  },
  "bugs": "https://github.com/Arilas/knip-gui/issues",
  "homepage": "https://github.com/Arilas/knip-gui#readme",
  "keywords": [
    "knip",
    "unused-code",
    "dead-code",
    "gui",
    "cleanup",
    "lint",
    "devtools"
  ],
  "bin": {
    "knip-gui": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "build:client": "NODE_ENV=production vite build --config client/vite.config.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx scripts/e2e-fixture.ts --reap-only && playwright test",
    "e2e:fixture": "tsx scripts/e2e-fixture.ts",
    "typecheck": "tsc --noEmit && tsc -p client/tsconfig.json && tsc -p tsconfig.tests.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "diff": "^9.0.0",
    "hono": "^4.12.30",
    "jsonc-parser": "^3.3.1",
    "magic-string": "^0.30.21",
    "open": "^11.0.0",
    "oxc-parser": "^0.137.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-virtual": "^3.14.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.12.2",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  }
}
