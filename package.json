{
  "name": "knip-gui",
  "version": "0.1.0",
  "description": "Web GUI for knip — browse, fix, and commit unused-code cleanups",
  "type": "module",
  "license": "MIT",
  "bin": {
    "knip-gui": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.30",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "knip": "^6.26.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
