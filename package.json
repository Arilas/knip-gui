{
  "name": "knip-gui",
  "version": "0.1.0",
  "description": "Web GUI for knip — browse, fix, and commit unused-code cleanups",
  "type": "module",
  "license": "MIT",
  "bin": {
    "knip-gui": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "build:client": "vite build --config client/vite.config.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p client/tsconfig.json"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.6",
    "diff": "^9.0.0",
    "hono": "^4.12.30",
    "jsonc-parser": "^3.3.1",
    "magic-string": "^0.30.21",
    "open": "^11.0.0",
    "oxc-parser": "^0.137.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "knip": "^6.26.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
